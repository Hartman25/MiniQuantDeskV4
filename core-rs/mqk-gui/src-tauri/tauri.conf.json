{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiniQuantDesk",
  "version": "0.1.0",
  "identifier": "com.zachhartman.miniquantdesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MiniQuantDesk",
        "width": 1720,
        "height": 1080,
        "minWidth": 1280,
        "minHeight": 820,
        "resizable": true,
        "maximized": false,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["desktop-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Finance",
    "shortDescription": "Institution-style operator console for MiniQuantDesk.",
    "longDescription": "MiniQuantDesk desktop operator console with execution, risk, reconcile, and runtime supervision.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}