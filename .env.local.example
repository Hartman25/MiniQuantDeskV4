# MiniQuantDesk V4 — .env.local.example
#
# Copy this file to .env.local and fill in real values for local development.
# .env.local is gitignored and must NEVER be committed.
#
# In production / CI, inject these variables directly via your secrets manager.
# The file is loaded at startup by mqk-cli and mqk-daemon (silent if absent).
#
# PATCH S1: All env var NAMES below are referenced in config/defaults/base.yaml.
# Only names live in config; values live here (or in your secrets manager).

# ---------------------------------------------------------------------------
# Broker — Alpaca (paper)
# ---------------------------------------------------------------------------
ALPACA_API_KEY_PAPER=your_alpaca_paper_api_key_here
ALPACA_API_SECRET_PAPER=your_alpaca_paper_api_secret_here
ALPACA_PAPER_BASE_URL="https://paper-api.alpaca.markets"
# Broker — Alpaca (live) — use a SEPARATE account; keep capped by config
ALPACA_API_KEY_LIVE=your_alpaca_live_api_key_here
ALPACA_API_SECRET_LIVE=your_alpaca_live_api_secret_here
# ENV-TRUTH-02: ALPACA_LIVE_BASE_URL is NOT read by the daemon.
# The live Alpaca endpoint is hardcoded to https://api.alpaca.markets for all
# live modes (LiveShadow, LiveCapital). Setting this env var has no effect.
# Only the PAPER endpoint is overridable via ALPACA_PAPER_BASE_URL above.
# ALPACA_LIVE_BASE_URL="https://api.alpaca.markets"
# ---------------------------------------------------------------------------
# Market data — TwelveData (primary)
# Extension point: add FMP_API_KEY here when FMP provider is wired
FMP_Key=
# ---------------------------------------------------------------------------
TWELVEDATA_API_KEY=
TWELVEDATA_BASE_URL="https://api.twelvedata.com"
# =========================
# DISCORD BOT (C2 CONTROL)
# =========================
# Slash-command bot token (NEVER commit real token values)
DISCORD_BOT_TOKEN=""

# Optional but recommended: restrict bot to a single guild
DISCORD_GUILD_ID=""

# ---------------------------------------------------------------------------
# Discord webhooks (all optional; missing channels are silently skipped)
# ---------------------------------------------------------------------------
DISCORD_WEBHOOK_PAPER=https://discord.com/api/webhooks/REPLACE_ME/paper
DISCORD_WEBHOOK_LIVE=https://discord.com/api/webhooks/REPLACE_ME/live
DISCORD_WEBHOOK_BACKTEST=https://discord.com/api/webhooks/REPLACE_ME/backtest
DISCORD_WEBHOOK_ALERTS=https://discord.com/api/webhooks/REPLACE_ME/alerts
DISCORD_WEBHOOK_HEARTBEAT=https://discord.com/api/webhooks/REPLACE_ME/heartbeat
DISCORD_WEBHOOK_C2=https://discord.com/api/webhooks/REPLACE_ME/c2

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
MQK_DATABASE_URL=postgres://postgres:postgres@localhost:5432/mqk_dev

# ---------------------------------------------------------------------------
# Daemon bind address (optional; defaults to 127.0.0.1:8899)
# ---------------------------------------------------------------------------
# MQK_DAEMON_ADDR=127.0.0.1:8899
# MQK_DAEMON_ALLOW_NETWORK_BIND=1   # ONLY set if you need a non-loopback address;
#                                   # daemon refuses startup without this opt-in

# ---------------------------------------------------------------------------
# Operator auth — REQUIRED in all non-dev deployments
# ---------------------------------------------------------------------------
# MQK_OPERATOR_TOKEN must be set before privileged routes (run/start, run/stop,
# halt, arm/disarm, ops/action, strategy/signal, etc.) will respond.
# Without it, all operator routes return 503 fail-closed.
# Use a strong random value (e.g. openssl rand -hex 32).
MQK_OPERATOR_TOKEN=replace_with_strong_random_secret

# Debug-only escape hatch: skip operator token in local dev builds ONLY.
# Has NO effect in release builds. Never set in staging/prod.
# MQK_DEV_ALLOW_NO_OPERATOR_TOKEN=1

# ---------------------------------------------------------------------------
# Deployment mode + broker adapter — REQUIRED for a runnable paper path
# ---------------------------------------------------------------------------
# Canonical paper-trading path: Paper + Alpaca.
# paper+paper is explicitly blocked (no bar-feed, never fills).
MQK_DAEMON_DEPLOYMENT_MODE=paper
MQK_DAEMON_ADAPTER_ID=alpaca

# ---------------------------------------------------------------------------
# Autonomous session window (UTC HH:MM, optional)
# ---------------------------------------------------------------------------
# When set, the autonomous session controller auto-starts the run at START
# and auto-stops it at STOP each trading day (NYSE regular session by default
# when both are absent). Set both or neither; partial config is ignored.
# MQK_SESSION_START_HH_MM=13:30   # 09:30 ET = 13:30 UTC
# MQK_SESSION_STOP_HH_MM=20:00    # 16:00 ET = 20:00 UTC

# ---------------------------------------------------------------------------
# Strategy artifact path — required to pass the artifact-intake gate at start
# ---------------------------------------------------------------------------
# Point to the promoted_manifest.json produced by the TV-01 research pipeline.
# If absent, start is allowed (gate is not enforced) but artifact truth is
# honestly surfaced as "not_configured" in /api/v1/system/artifact-intake.
# MQK_ARTIFACT_PATH=/path/to/promoted/signal_packs/<id>/promoted_manifest.json

# ---------------------------------------------------------------------------
# Capital allocation policy — REQUIRED for live-capital mode
# ---------------------------------------------------------------------------
# Point to capital_allocation_policy.json (schema policy-v1).
# Paper and live-shadow modes do not require this; live-capital fails closed
# without it. Absent = not enforced (paper/live-shadow pass through).
# MQK_CAPITAL_POLICY_PATH=/path/to/policies/<run>/capital_allocation_policy.json
