###############################
# MiniQuantDesk V4 – .gitignore
###############################

# -----------------------------
# Rust build artifacts
# -----------------------------
target/
**/target/

# Keep repo-level Cargo config if you have it; ignore only cargo caches
.cargo/registry/
.cargo/git/

# -----------------------------
# Environment / secrets
# -----------------------------
.env
.env.*
!.env.local.example
secrets.env
secrets.local
*.pem
*.key

# -----------------------------
# Runtime / generated data
# -----------------------------
exports/
runtime/
!core-rs/mqk-gui/src/features/runtime/
!core-rs/mqk-gui/src/features/runtime/RuntimeScreen.tsx
logs/
*.log

# Research run artifacts (deterministic outputs, not source)
research-py/runs/
research-py/runs_*/

# Coverage / profiling outputs
coverage/
*.profraw
*.profdata

# -----------------------------
# Python
# -----------------------------
__pycache__/
**/__pycache__/
*.py[cod]

# Virtual environments
.venv/
venv/
env/
.venv*/
venv*/
env*/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.eggs/
*.egg-info/

# Compiled extensions (common in scientific stacks)
*.so
*.pyd
*.dll
*.dylib

# -----------------------------
# Node / GUI
# -----------------------------
node_modules/
dist/
build/
*.tsbuildinfo

# -----------------------------
# AI / local tooling scratch
# -----------------------------
.claude/
.claude-worktrees/
**/.claude/
.worktree_rescue/
.continue/
continue/

# -----------------------------
# Local archives / dumps
# -----------------------------
*.zip
*.7z
*.tar
*.tar.gz

repo_tree.txt
core_rs_dirs.txt
cargo_tomls.txt

MiniQuantDeskV4__SOURCE.zip
MiniQuantDeskV4_repo.zip
MiniQuantDeskV4_core-rs.zip
research-py/src/*.egg-info/
*.egg-info/
# -----------------------------
# OS / editor junk
# -----------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*.tmp
.idea/
.vscode/

# -----------------------------
# Office temp/lock files only
# -----------------------------
~$*.docx
